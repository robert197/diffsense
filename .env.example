# --- GitHub App (one-time registration in the GitHub UI; see README) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- LLM (reserved; NOT consumed or validated in this slice — see packages/llm, issue #8) ---
LLM_PROVIDER=anthropic
REVIEW_MODEL=claude-opus-4-8
SYNTHESIS_MODEL=claude-fable-5
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- Infra (default to the docker-compose services; accept any external host) ---
DATABASE_URL=postgres://diffsense:diffsense@localhost:5432/diffsense
REDIS_URL=redis://localhost:6379

# --- Ingress ---
PORT=3000
