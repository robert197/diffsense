# --- GitHub App (one-time registration in the GitHub UI; see README) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- LLM (consumed by packages/llm; provider + models resolved from env, issue #8) ---
# LLM_PROVIDER selects the vendor: anthropic | openai | google.
# REVIEW_MODEL / SYNTHESIS_MODEL default to the Anthropic models below; set them
# when using another provider. Top-risk chunks route to SYNTHESIS_MODEL.
# apps/web also reads these to localize card prose into the reviewer's chosen
# spoken language (issue #28); if unset, the deck simply renders in English.
LLM_PROVIDER=anthropic
REVIEW_MODEL=claude-opus-4-8
SYNTHESIS_MODEL=claude-fable-5
# Set the API key for the chosen provider.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# --- Infra (default to the docker-compose services; accept any external host) ---
DATABASE_URL=postgres://diffsense:diffsense@localhost:5432/diffsense
REDIS_URL=redis://localhost:6379

# --- Ingress ---
PORT=3000
# Public URL of the ingress. Used to build the 👍/👎 reaction links in the
# ranked comment. Leave unset to render the comment without the affordance.
# PUBLIC_BASE_URL=https://diffsense.example.com

# --- Card view + reviewer entry path (apps/web, issues #13/#25) ---
# Public URL of the hosted web app. Used both to link the ranked comment to the
# per-PR cards at /pr/<owner>/<repo>/<number> (#13) AND as the OAuth redirect base
# (#25): the callback is ${WEB_BASE_URL}/api/auth/callback. For local Docker this
# is http://localhost:3001.
WEB_BASE_URL=http://localhost:3001

# --- Reviewer sign-in (apps/web, issue #25) ---
# GitHub App user-authorization (OAuth). Distinct from GITHUB_APP_ID/PRIVATE_KEY:
# generate a client secret on the same GitHub App, enable "Request user
# authorization (OAuth) during installation", and set the callback URL to
# ${WEB_BASE_URL}/api/auth/callback.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# High-entropy random string (>= 16 chars) used to derive the AES key that
# encrypts stored GitHub tokens at rest. Generate with: openssl rand -base64 32
SESSION_SECRET=
