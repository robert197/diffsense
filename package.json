{
  "name": "diffsense",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx apps/app/src/db/migrate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@ast-grep/napi", "@biomejs/biome", "esbuild", "msgpackr-extract"],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
